# ============================================================
# Production environment variables for Research Center
# Copy to .env.production (or inject via your secret manager)
# before deploying. NEVER commit the real .env.production.
# ============================================================

# ---- Auth (required) ----
AUTH_SECRET=                          # 32+ chars, openssl rand -base64 48
AUTH_BASE_URL=https://research.your-domain                # for OAuth redirect_uri
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=linegoapp.com    # or use ALLOWED_EMAILS instead
# ALLOWED_EMAILS=alice@example.com,bob@example.com
EDITOR_EMAILS=                        # comma-separated; others become viewer
# AUTH_DEV_BYPASS must NOT be set in production

# ---- AI / Embedding (required for AI features) ----
GEMINI_API_KEY=

# ---- Optional external APIs ----
GOOGLE_DRIVE_API_KEY=                 # for /api/reports/import-drive
FIRECRAWL_API_KEY=                    # for social/firecrawl features

# ---- Cron (required if /api/social/cron is scheduled) ----
# CRON_SECRET=                        # Vercel Cron / k8s CronJob -> Bearer <secret>

# ---- Global daily quotas (optional, defaults shown) ----
# QUOTA_GEMINI_CHAT_PER_DAY=100
# QUOTA_GEMINI_CHAT_PRO_PER_DAY=50
# QUOTA_GEMINI_EMBEDDING_PER_DAY=2000
# QUOTA_FIRECRAWL_PER_DAY=50

# ---- Per-user quotas (optional, defaults shown) ----
# QUOTA_USER_CHAT_EDITOR=60
# QUOTA_USER_CHAT_PRO_EDITOR=10
# QUOTA_USER_EMBEDDING_EDITOR=1000
# QUOTA_USER_FIRECRAWL_EDITOR=30
# QUOTA_USER_CHAT_VIEWER=30
# QUOTA_USER_CHAT_PRO_VIEWER=0
# QUOTA_USER_EMBEDDING_VIEWER=500
# QUOTA_USER_FIRECRAWL_VIEWER=10

# ---- Next.js runtime ----
# PORT=3000                           # already set in Dockerfile
# HOSTNAME=0.0.0.0                    # already set in Dockerfile
NODE_ENV=production
