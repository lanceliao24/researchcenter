# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Google Drive API Key（啟用 Drive API 後產生；用於報告中心「從 Google Drive 匯入」）
GOOGLE_DRIVE_API_KEY=your-drive-api-key

# Firecrawl
FIRECRAWL_API_KEY=your-firecrawl-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Auth ───
# HMAC secret for session JWT (32+ chars). Generate: openssl rand -base64 48
AUTH_SECRET=replace-with-32-char-random-string

# Public base URL used to build OAuth redirect_uri.
# Defaults to request origin; set explicitly when behind a proxy/load balancer.
# AUTH_BASE_URL=https://research.example.com

# Google OAuth client (Cloud Console → APIs & Services → Credentials)
# Authorized redirect URI: <AUTH_BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Authorized email allowlist (use either or both):
ALLOWED_EMAIL_DOMAIN=linegoapp.com
# ALLOWED_EMAILS=alice@x.com,bob@y.com   # additional individual addresses

# Editors (full mutation permissions). Others are viewers (read-only / AI usage).
EDITOR_EMAILS=

# Local dev only: skip auth and grant editor session.
# Requires NODE_ENV=development; ignored in production.
# AUTH_DEV_BYPASS=1

# Bearer token for cron endpoints (e.g. Vercel Cron → /api/social/cron)
# CRON_SECRET=replace-with-random-string

# ─── Per-user AI quota (overrides defaults) ───
# Defaults: editor 60 chat / 1000 embed / 30 firecrawl per day, viewer 30 / 500 / 10
# QUOTA_USER_CHAT_EDITOR=60
# QUOTA_USER_EMBEDDING_EDITOR=1000
# QUOTA_USER_FIRECRAWL_EDITOR=30
# QUOTA_USER_CHAT_VIEWER=30
# QUOTA_USER_EMBEDDING_VIEWER=500
# QUOTA_USER_FIRECRAWL_VIEWER=10
